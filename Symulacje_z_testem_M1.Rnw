M1_stat_fast <- function(x) {

  N <- length(x)

  xt <- (x - mean(x)) / sd(x)

  diff <- outer(xt, xt, "-")
  diff_sq <- diff^2
  
  A <- outer(diff_sq, diff_sq, "+")
  sum1 <- sum(besselJ(sqrt(A), 0))

  xt2 <- xt^2
  B <- outer(xt2, xt2, "+")
  sum2 <- sum(besselJ(sqrt(B), 0))

  M1 <- 2 * pi * N * ((1/N^4) * sum1 - exp(-1/2) * (2/N^2) * sum2 + exp(-1))

  return(M1)
}


