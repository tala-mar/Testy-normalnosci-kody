#rozkłady
distributions <- c(
  "normal", "t3", "cauchy", "lognormal",
  "gamma", "chisq", "exponential", "mixed_normal"
)

generate_sample <- function(n, dist_name) {

  switch(dist_name,

    "normal" = rnorm(n),
    "t3" = rt(n, df = 3),
    "cauchy" = rcauchy(n, 0, 2),
    "lognormal" = rlnorm(n),
    "gamma" = rgamma(n, 3, 2),
    "chisq" = rchisq(n, 2),
    "exponential" = rexp(n),
    "mixed_normal" = {
      n1 <- floor(n / 2)
      n2 <- n - n1
      sample(c(rnorm(n1, 0, 1), rnorm(n2, 3, 1)))
    }
  )
}


run_simulation <- function(n_sim, n) {

  results_list <- list()

