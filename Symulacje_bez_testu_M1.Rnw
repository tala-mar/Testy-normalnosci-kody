\section{Błąd pierwszego rodzaju}
<<Blad_I, echo=FALSE, warning=FALSE>>=
run_tests_bez_M1 <- function(x) {
  
  res <- c(
    SW = shapiro.test(x)$p.value,
    AD = ad.test(x)$p.value,
    KS = ks.test(x, "pnorm", mean = 0, sd = 1)$p.value,
    CVM = cvm.test(x)$p.value,
    LF = lillie.test(x)$p.value,
    JB = jarque.bera.test(x)$p.value,
    DA = unname(dagoTest(x)@test$p.value[1]),
    SF = ShapiroFranciaTest(x)$p.value,
    Zone = zone_test(x)
  )
  
  return(res)
}

blad_I_rodzaju <- function(n_sim, n, alpha = 0.05) {
  
  p_matrix <- t(future_replicate(
    n_sim,
    run_tests_bez_M1(rnorm(n)),
    future.seed = TRUE
  ))
  
  rejection_rate <- colMeans(p_matrix <= alpha)
  
  wynik <- data.frame(
    n = n,
    MC = n_sim,
    t(rejection_rate),
    check.names = FALSE
  )
  
  return(wynik)
}
set.seed(123)

n_values <- c(25, 50, 100, 500)
mc_values <- c(500, 1000, 5000)

tabela_blad_I <- do.call(
  rbind,
  lapply(mc_values, function(mc) {
    do.call(
      rbind,
      lapply(n_values, function(n) {
        blad_I_rodzaju(n_sim = mc, n = n)
      })
    )
  })
)

rownames(tabela_blad_I) <- NULL
@

<<tabele_blad_I, echo=FALSE, results='asis', warning=FALSE>>=
tabela_MC_500 <- subset(tabela_blad_I, MC == 500)
tabela_MC_1000 <- subset(tabela_blad_I, MC == 1000)
tabela_MC_5000 <- subset(tabela_blad_I, MC == 5000)

kable(tabela_MC_500, caption = "Empiryczny błąd pierwszego rodzaju, MC = 500", digits = 3, row.names = FALSE)

kable(tabela_MC_1000, caption = "Empiryczny błąd pierwszego rodzaju, MC = 1000", digits = 3, row.names = FALSE)

kable(tabela_MC_5000, caption = "Empiryczny błąd pierwszego rodzaju, MC = 5000", digits = 3, row.names = FALSE)
@


