  geom_hline(yintercept = 0.05, linetype = "dashed") +
  scale_x_continuous(breaks = c(25, 50, 100, 500)) +
  
  labs(
    x = "Liczebność próby n",
    y = "Empiryczny błąd I rodzaju",
    color = "Test"
  ) +
  theme_minimal()
@

<<wykresy_mocy, echo=FALSE, warning=FALSE, message=FALSE>>=

przygotuj_dane_mocy <- function(lista_wynikow, liczebnosci) {
  testy <- c("SW", "AD", "CVM", "LF", "JB", "DA", "SF", "Zone")
  dane <- data.frame()
  
  for (i in seq_along(lista_wynikow)) {

    tabela <- lista_wynikow[[i]]
    tabela$n <- liczebnosci[i]
    tabela <- tabela[, c("Distribution", "n", testy)]
    dane <- rbind(dane, tabela)
  }

  dane_dlugie <- data.frame()
  for (test in testy) {

    fragment <- data.frame(
      Distribution = dane$Distribution,
      n = dane$n,
      Test = test,
      Moc = dane[[test]]
    )

    dane_dlugie <- rbind(dane_dlugie, fragment)
  }

  nazwy_rozkladow <- c(
    "t3" = "t(3)",
    "cauchy" = "Cauchy",
    "lognormal" = "Lognormalny",
    "gamma" = "Gamma",
    "chisq" = "Chi-kwadrat (2)",
    "exponential" = "Wykładniczy",
    "mixed_normal" = "Mieszany normalny"
  )

  dane_dlugie$Rozklad <-
    nazwy_rozkladow[dane_dlugie$Distribution]

  dane_dlugie$n <- factor(
    dane_dlugie$n,
    levels = c(25, 50, 100, 500)
  )

  dane_dlugie$Test <- factor(
    dane_dlugie$Test,
    levels = testy
  )

  dane_dlugie$Rozklad <- factor(
    dane_dlugie$Rozklad,
    levels = c(
      "t(3)",
      "Cauchy",
      "Lognormalny",
      "Gamma",
      "Chi-kwadrat (2)",
      "Wykładniczy",
      "Mieszany normalny"
    )
  )

  return(dane_dlugie)
}
dane_moc_500 <- przygotuj_dane_mocy(
  lista_wynikow = list(
    wyniki1_moc,
    wyniki2_moc,
    wyniki3_moc,
    wyniki4_moc
  ),
  liczebnosci = c(25, 50, 100, 500)
)

