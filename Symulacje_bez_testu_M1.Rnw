nazwy_plikow <- c(
  "t(3)" = "t3",
  "Cauchy" = "cauchy",
  "Lognormalny" = "lognormalny",
  "Gamma" = "gamma",
  "Chi-kwadrat (2)" = "chi_kwadrat",
  "Wykładniczy" = "wykladniczy",
  "Mieszany normalny" = "mieszany_normalny"
)

zapisz_wykresy_mocy <- function(dane, MC) {

  lista_wykresow <- list()
  for (rozklad in levels(dane$Rozklad)) {

    dane_wykres <- dane[dane$Rozklad == rozklad, ]
    wykres <- ggplot(
      dane_wykres,
      aes(
        x = n,
        y = Moc,
        group = Test,
        color = Test
      )
    ) +
      geom_line(linewidth = 0.9) +
      geom_point(size = 2.5) +
      scale_y_continuous(
        limits = c(0, 1),
        breaks = seq(0, 1, by = 0.1)
      ) +
      labs(
        x = "Liczebność próby",
        y = "Moc",
        color = "Test"
      ) +
      theme_minimal(base_size = 12) +
      theme(
        plot.title = element_text(
          hjust = 0.5,
          face = "bold"
        ),
        legend.position = "bottom",
        legend.title = element_text(face = "bold"),
        panel.grid.minor = element_blank()
      ) +
      guides(
        color = guide_legend(nrow = 1)
      )

    nazwa_pliku <- paste0(
      "moc_",
      nazwy_plikow[rozklad],
      "_MC",
      MC,
      ".pdf"
    )

    ggsave(
      filename = nazwa_pliku,
      plot = wykres,
      width = 9,
      height = 6
    )

    lista_wykresow[[rozklad]] <- wykres
  }

  return(lista_wykresow)
}

@

<<wykresy_moc, echo=FALSE, warning=FALSE, message=FALSE>>=
wykresy_moc_500 <- zapisz_wykresy_mocy(
  dane = dane_moc_500,
  MC = 500
)

wykresy_moc_5000 <- zapisz_wykresy_mocy(
  dane = dane_moc_5000,
  MC = 5000
)
@

